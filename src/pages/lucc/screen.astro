---
import '@/styles.css';
import BusDepartures from '@/components/BusDepartures';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LUCC Screen Info</title>
    <meta name="robots" content="noindex" />
    <script
      is:inline
      defer
      data-domain="lumacs.co.uk"
      src="https://ingest.tokia.dev/js/script.outbound-links.js"></script>
    <script is:inline>
      window.plausible =
        window.plausible ||
        function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
    </script>
    <style>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background:
          radial-gradient(
            circle at top left,
            rgba(234, 88, 12, 0.22),
            transparent 34%
          ),
          radial-gradient(
            circle at bottom right,
            rgba(37, 99, 235, 0.18),
            transparent 28%
          ),
          #050816;
      }

      body {
        color: white;
      }
    </style>
  </head>
  <body>
    <main class="grid h-full w-full grid-cols-2 grid-rows-2 gap-0">
      <section
        class="min-h-0 min-w-0 border-b border-r border-white/10 bg-black/20"
      >
        <div class="relative h-full w-full overflow-hidden">
          <iframe
            src="https://timetable.lumacs.co.uk/?hideLayout=0"
            title="LUCC workshop timetable"
            class="absolute left-0 top-0 border-0"
            style="
      --scale: 0.6;
      width: calc(100% / var(--scale));
      height: calc(100% / var(--scale));
      transform: scale(var(--scale));
      transform-origin: top left;
    "
          ></iframe>
        </div>
      </section>

      <section class="min-h-0 min-w-0 border-b border-white/10 bg-black/20">
        <BusDepartures client:load />
      </section>

      <section class="min-h-0 min-w-0 border-r border-white/10 bg-black/20">
        <div class="h-full overflow-hidden p-4">
          <img
            src="/assets/lucc/event.png"
            alt="LICA Building Map for LUCC 2026"
            class="h-full w-full rounded-2xl object-contain"
            loading="lazy"
          />
        </div>
      </section>

      <section class="min-h-0 min-w-0 bg-black/20">
        <div class="h-full overflow-hidden p-4">
          <img
            src="/assets/lucc/campus.png"
            alt="Lancaster University Campus Map for LUCC 2026"
            class="h-full w-full rounded-2xl object-contain"
            loading="lazy"
          />
        </div>
      </section>
    </main>
  </body>
</html>
